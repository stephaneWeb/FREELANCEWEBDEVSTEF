{% extends 'base.html.twig' %}

{% block title %}
	Contact | Atelier Halo
{% endblock %}

{% block body %}

	<section class="contact-page-section">
		<div class="container">
			<div class="contact-page-panel">
				<div class="row align-items-center g-5">

					<div class="col-lg-7">

						<a href="{{ path('app_home') }}" class="contact-back-btn">
							<span>←</span>
							Retour à l’accueil
						</a>

						<span class="section-badge">Contact</span>

						<h1>Parlons de votre projet.</h1>

						<p>
							Décrivez votre besoin et je vous répondrai
							                        avec une première analyse claire.
						</p>

						{% for message in app.flashes('success') %}
							<div class="contact-alert success-alert">
								{{ message }}
							</div>
						{% endfor %}

						{% for message in app.flashes('error') %}
							<div class="contact-alert error-alert">
								{{ message }}
							</div>
						{% endfor %}

						{{ form_start(contactForm, {
                        attr: {
                            class: 'contact-form'
                        }
                    }) }}

						<input type="hidden" name="formTime" value="{{ formTime }}">

						<div class="mb-4">
							{{ form_label(contactForm.name, null, {
                                label_attr: {
                                    class: 'form-label contact-label'
                                }
                            }) }}
							{{ form_widget(contactForm.name) }}
							{{ form_errors(contactForm.name) }}
						</div>

						<div class="mb-4">
							{{ form_label(contactForm.email, null, {
                                label_attr: {
                                    class: 'form-label contact-label'
                                }
                            }) }}
							{{ form_widget(contactForm.email) }}
							{{ form_errors(contactForm.email) }}
						</div>

						<div class="mb-4">
							{{ form_label(contactForm.subject, null, {
                                label_attr: {
                                    class: 'form-label contact-label'
                                }
                            }) }}
							{{ form_widget(contactForm.subject) }}
							{{ form_errors(contactForm.subject) }}
						</div>

						<div class="mb-4">
							{{ form_label(contactForm.message, null, {
                                label_attr: {
                                    class: 'form-label contact-label'
                                }
                            }) }}
							{{ form_widget(contactForm.message) }}
							{{ form_errors(contactForm.message) }}
						</div>
                            <div class="d-none">
    {{ form_row(contactForm.website) }}
</div>
						<button type="submit" class="btn btn-light contact-submit">
							Envoyer le message
						</button>

						{{ form_end(contactForm) }}

					</div>

					<div class="col-lg-5">
						<div class="contact-logo-wrapper">
							<img src="{{ asset('images/logo-atelier-halo.webp') }}" alt="Atelier Halo" class="contact-logo">
						</div>
					</div>

				</div>
			</div>
		</div>
	</section>

{% endblock %}
